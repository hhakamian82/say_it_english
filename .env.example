# Database Connection
# Get this from Supabase: Project Settings > Database > Connection String > URI
# Make sure to enable "Use connection pooling" and replace [YOUR-PASSWORD] with your actual password
DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres

# Environment
NODE_ENV=development

# AvalAI (OpenAI-compatible gateway for GPT/Claude/Gemini) — used by /api/chat
# Get your key from https://avalai.ir dashboard. Put the real value in .env.local, never here.
AVALAI_API_KEY=
# Optional overrides — defaults are https://api.avalai.ir/v1 and gpt-4o-mini
# AVALAI_BASE_URL=https://api.avalai.ir/v1
# AVALAI_MODEL=gpt-4o-mini
