# Database Connection
# Get this from Supabase: Project Settings > Database > Connection String > URI
# Make sure to enable "Use connection pooling" and replace [YOUR-PASSWORD] with your actual password
DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres

# Environment
NODE_ENV=development

# AvalAI (OpenAI-compatible gateway for GPT/Claude/Gemini) — used by /api/chat
# Get your key from https://avalai.ir dashboard. Put the real value in .env.local, never here.
AVALAI_API_KEY=
# Optional overrides — defaults are https://api.avalai.ir/v1 and gpt-4o-mini
# AVALAI_BASE_URL=https://api.avalai.ir/v1
# AVALAI_MODEL=gpt-4o-mini

# Instagram DM Drafter (HITL) — auth token for POST /api/ig/draft and PATCH /api/ig/draft/:id.
# Generate a long random value (e.g. `openssl rand -hex 24`). Put the real value in .env.local
# and Vercel Project Settings, never here. Sent as "Authorization: Bearer <token>" — while
# unset, the endpoints stay closed (401).
IG_DRAFT_TOKEN=

# ZarinPal (real payment gateway) — used by /api/payment/request and /api/payment/verify
# Get your Merchant ID from https://next.zarinpal.com dashboard. Put the real value in .env.local, never here.
ZARINPAL_MERCHANT_ID=
# Set to "true" to use ZarinPal's sandbox (test) environment instead of production
# ZARINPAL_SANDBOX=true

# Group-class online payment gate. Keep unset/false until the ZarinPal merchant above is
# confirmed working end-to-end — until then, students enroll via manual card-to-card/crypto only.
# ENABLE_ONLINE_CLASS_PAYMENT=false

# Upstash Redis (optional) — makes rate limiting work correctly across serverless invocations.
# Without these, rate limiting silently falls back to an in-memory Map that only works per warm instance.
# Get both from your Upstash Redis database's REST API tab: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ArvanCloud S3-compatible Object Storage — used by /api/admin/upload (content upload)
# and /api/download (secure, purchase-gated video streaming/download in production).
# ARVAN_S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
# ARVAN_S3_BUCKET=
# ARVAN_S3_ACCESS_KEY=
# ARVAN_S3_SECRET_KEY=

# sms.ir — used for OTP login (SMS_IR_TEMPLATE_ID) and, optionally, sending the class
# meet link after enrollment (SMS_IR_CLASS_TEMPLATE_ID). The class-link template needs a
# "LINK" parameter approved in the sms.ir panel; without it, SMS is skipped silently and
# students still see the link in their dashboard (the primary delivery channel).
# SMS_IR_API_KEY=
# SMS_IR_TEMPLATE_ID=
# SMS_IR_CLASS_TEMPLATE_ID=
